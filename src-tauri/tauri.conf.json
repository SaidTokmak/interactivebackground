{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "interactivebackground",
  "version": "0.2.0-1",
  "identifier": "com.saidtokmak.interactivebackground",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "control",
        "title": "interactivebackground",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620,
        "center": true
      },
      {
        "label": "wallpaper",
        "title": "interactivebackground Wallpaper",
        "width": 1280,
        "height": 720,
        "resizable": false,
        "decorations": false,
        "shadow": false,
        "skipTaskbar": true,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Turkish", "English"],
        "displayLanguageSelector": true,
        "startMenuFolder": "interactivebackground"
      },
      "wix": {
        "upgradeCode": "87d06055-f5ac-5cc7-8fc3-fd9d28902c89",
        "language": ["tr-TR", "en-US"]
      }
    }
  }
}
