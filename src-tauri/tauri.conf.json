{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flowdesk",
  "version": "0.1.0",
  "identifier": "com.flowdesk.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "control",
        "title": "Flowdesk",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620,
        "center": true
      },
      {
        "label": "wallpaper",
        "title": "Flowdesk Wallpaper",
        "width": 1280,
        "height": 720,
        "resizable": false,
        "decorations": false,
        "shadow": false,
        "skipTaskbar": true,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
